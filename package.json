{
  "name": "torch-football",
  "version": "0.40.0",
  "type": "module",
  "description": "TORCH — The Football Card Game",
  "scripts": {
    "dev": "vite",
    "tunnel": "lt --port 5173 --subdomain brock-torch",
    "test": "node --input-type=module -e \"import { runSmokeTest } from './src/tests/smokeTest.js'; runSmokeTest();\" && node --input-type=module -e \"import { runPersistenceTest } from './src/tests/persistenceTest.js'; runPersistenceTest();\" && node --input-type=module -e \"import { runUiLogicTest } from './src/tests/uiLogicTest.js'; runUiLogicTest();\" && node --input-type=module -e \"import { runGameSim } from './src/tests/gameSimTest.js'; runGameSim(25);\"",
    "build": "vite build",
    "preview": "vite preview",
    "dev:api": "vercel dev",
    "deploy": "git add -A && git commit -m 'deploy' && git push && vercel --prod",
    "deploy:preview": "vercel"
  },
  "keywords": [
    "football",
    "card-game",
    "daily-puzzle"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2",
    "vite": "^8.0.0",
    "vite-plugin-qrcode": "^0.4.1"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/italiana": "^5.2.8",
    "@fontsource/josefin-sans": "^5.2.8",
    "@fontsource/major-mono-display": "^5.2.8",
    "@fontsource/marcellus": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/righteous": "^5.2.7",
    "@fontsource/teko": "^5.2.7",
    "@fontsource/zilla-slab": "^5.2.8",
    "@lottiefiles/dotlottie-web": "^0.70.0",
    "gsap": "^3.14.2",
    "howler": "^2.2.4"
  }
}
