<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>TORCH Team Select — Mockup</title>
<link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;500;600;700;900&family=Rajdhani:wght@400;500;600;700&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  html, body {
    height:100%; width:100%; overflow:hidden;
    background:#0A0804; color:#fff;
    font-family:'Rajdhani',sans-serif;
  }

  .screen {
    position:fixed; inset:0;
    display:flex; flex-direction:column;
    background:#0A0804;
    overflow:hidden;
  }

  /* ── HEADER BAR ── */
  .header-bar {
    flex-shrink:0;
    display:flex; justify-content:space-between; align-items:center;
    padding:10px 16px;
    background:rgba(0,0,0,0.6);
    border-bottom:2px solid #FFB800;
    z-index:10;
  }
  .header-title {
    font-family:'Teko'; font-weight:700; font-size:22px;
    color:#FFB800; letter-spacing:3px;
    font-style:italic; transform:skewX(-8deg);
    text-shadow:2px 2px 0 rgba(0,0,0,0.9);
  }
  .back-btn {
    font-family:'Rajdhani'; font-size:10px; font-weight:600;
    padding:8px 14px; cursor:pointer;
    background:#000; color:#fff;
    border:2px solid #333; border-radius:4px;
    letter-spacing:1px;
  }

  /* ── INSTRUCTION AREA ── */
  .instruction {
    flex-shrink:0;
    text-align:center;
    padding:10px 20px 4px;
  }
  .instruction-main {
    font-family:'Teko'; font-weight:700; font-size:22px;
    color:#FFB800; letter-spacing:3px;
  }
  .instruction-sub {
    font-family:'Rajdhani'; font-weight:500; font-size:12px;
    color:rgba(255,255,255,0.4); letter-spacing:1px;
    margin-top:2px;
  }

  /* ── TEAM GRID — fill the screen ── */
  .team-grid {
    flex:1;
    display:grid;
    grid-template-columns:1fr 1fr;
    grid-template-rows:1fr 1fr;
    gap:12px;
    padding:8px 16px 8px;
  }

  /* ── TEAM CARD ── */
  .team-card {
    position:relative;
    border-radius:12px;
    overflow:hidden;
    cursor:pointer;
    min-height:0;
    transition:all 0.25s cubic-bezier(0.22,1.3,0.36,1);
    opacity:0;
    animation:cardIn 0.35s ease-out both;
  }
  .team-card:nth-child(1) { animation-delay:0s; }
  .team-card:nth-child(2) { animation-delay:0.08s; }
  .team-card:nth-child(3) { animation-delay:0.16s; }
  .team-card:nth-child(4) { animation-delay:0.24s; }

  .team-card:active {
    transform:scale(1.05);
  }

  .card-bg {
    position:absolute; inset:0; z-index:0;
  }
  .card-content {
    position:relative; z-index:1;
    display:flex; flex-direction:column;
    align-items:center;
    height:100%;
    padding:10px 8px 10px;
  }

  /* Badge area — fill the card */
  .card-badge {
    flex:1;
    display:flex; align-items:center; justify-content:center;
    filter:drop-shadow(0 6px 16px rgba(0,0,0,0.6));
    width:100%;
  }

  /* Info area */
  .card-info {
    width:100%;
    display:flex; flex-direction:column;
    align-items:center;
    gap:3px;
  }
  .card-school {
    font-family:'Rajdhani'; font-weight:700; font-size:12px;
    color:rgba(255,255,255,0.45); letter-spacing:4px;
    text-transform:uppercase;
  }
  .card-team-name {
    font-family:'Teko'; font-weight:700; font-size:24px;
    color:#fff; letter-spacing:3px; line-height:1;
    text-shadow:1px 2px 0 rgba(0,0,0,0.8);
    margin-top:-1px;
  }

  /* Scheme pill — the key differentiator */
  .card-scheme {
    font-family:'Rajdhani'; font-weight:700; font-size:10px;
    letter-spacing:2px;
    padding:3px 12px; border-radius:10px;
  }

  /* One-liner vibe */
  .card-vibe {
    font-family:'Rajdhani'; font-weight:500; font-size:10px;
    color:rgba(255,255,255,0.40);
    text-align:center;
    line-height:1.3;
    padding:0 4px;
    max-width:150px;
  }

  /* Ratings row — symmetrical OFF | DEF layout */
  .card-ratings {
    display:flex; align-items:center; gap:12px;
    margin-top:5px;
    justify-content:center;
  }
  .rating-group {
    display:flex; align-items:center; gap:4px;
  }
  .rating-label {
    font-family:'Rajdhani'; font-size:10px; font-weight:700;
    color:#888; letter-spacing:2px;
  }
  .rating-divider {
    width:1px; height:14px;
    background:rgba(255,255,255,0.12);
  }

  /* Flame pip — green OFF, blue DEF to match pregame */
  .fp { width:11px; height:13px; }

  /* ── PLAY STYLE HINT (first-time only) ── */
  .style-hint {
    flex-shrink:0;
    text-align:center;
    padding:4px 20px 12px;
    opacity:0;
    animation:fadeUp 0.5s ease-out 0.5s both;
  }
  .style-hint-text {
    font-family:'Rajdhani'; font-weight:600; font-size:11px;
    color:rgba(255,255,255,0.25);
    letter-spacing:2px;
  }
  .style-hint-text span {
    color:#FFB800;
  }

  /* ── DIFFICULTY ROW ── */
  .diff-row {
    flex-shrink:0;
    display:flex; gap:8px;
    justify-content:center;
    padding:4px 32px 14px;
    opacity:0;
    animation:fadeUp 0.4s ease-out 0.4s both;
  }
  .diff-btn {
    flex:1;
    font-family:'Rajdhani'; font-weight:700; font-size:10px;
    letter-spacing:2px;
    padding:8px 12px;
    border-radius:4px;
    border:2px solid #333;
    background:transparent;
    color:#aaa;
    cursor:pointer;
    transition:all 0.2s;
  }
  .diff-btn.active-easy { background:#00ff44; color:#000; border-color:#00ff44; }
  .diff-btn.active-med { background:#FFB800; color:#000; border-color:#FFB800; }
  .diff-btn.active-hard { background:#ff0040; color:#000; border-color:#ff0040; }

  /* ── ANIMATIONS ── */
  @keyframes cardIn {
    0% { opacity:0; transform:translateY(30px) scale(0.9); }
    100% { opacity:1; transform:none; }
  }
  @keyframes fadeUp {
    0% { opacity:0; transform:translateY(8px); }
    100% { opacity:1; transform:translateY(0); }
  }

  /* ── SELECTED STATE ── */
  .team-card.selected {
    transform:scale(1.08);
    z-index:10;
  }
  .team-card.dimmed {
    opacity:0.35;
    transform:scale(0.95);
    filter:brightness(0.5);
  }
</style>
</head>
