<script>
  // Fix all flame pips: green for OFF, blue for DEF (matching pregame VS screen)
  document.querySelectorAll('.rating-group').forEach(group => {
    const label = group.querySelector('.rating-label');
    const isOff = label && label.textContent.trim() === 'OFF';
    const color = isOff ? '#00ff44' : '#4488ff';
    group.querySelectorAll('.fp path').forEach(p => p.setAttribute('fill', color));
  });

  // Interactive demo: tap to select
  document.querySelectorAll('.team-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.team-card').forEach(c => {
        if (c === card) {
          c.classList.toggle('selected');
          c.classList.remove('dimmed');
        } else {
          c.classList.toggle('dimmed', card.classList.contains('selected'));
          c.classList.remove('selected');
        }
      });
    });
  });
</script>

